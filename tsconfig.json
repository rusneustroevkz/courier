{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": "./",
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "static/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}